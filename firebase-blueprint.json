{
  "entities": {
    "inquiry": {
      "title": "Inquiry",
      "description": "A message sent by a user through the contact form.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "message": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email", "message", "createdAt"]
    },
    "video": {
      "title": "Video",
      "description": "Cached YouTube video metadata.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "date": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "date", "updatedAt"]
    },
    "course": {
      "title": "Course",
      "description": "A premium nursing course.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "string" },
        "originalPrice": { "type": "string" },
        "image": { "type": "string" },
        "category": { "type": "string" },
        "instructor": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "role": { "type": "string" },
            "image": { "type": "string" }
          }
        },
        "learningOutcomes": { "type": "array", "items": { "type": "string" } },
        "curriculum": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "title": { "type": "string" },
              "topics": { "type": "array", "items": { "type": "string" } }
            }
          }
        },
        "students": { "type": "string" },
        "rating": { "type": "number" },
        "duration": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "price", "category", "createdAt"]
    },
    "note": {
      "title": "Note",
      "description": "Study notes or previous papers.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "pdfUrl": { "type": "string" },
        "documentUrl": { "type": "string" },
        "isPremium": { "type": "boolean" },
        "price": { "type": "string" },
        "type": { "type": "string", "enum": ["note", "paper"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "pdfUrl", "type", "createdAt"]
    },
    "quiz": {
      "title": "Quiz",
      "description": "An interactive quiz or mock test.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "durationMinutes": { "type": "number" },
        "sections": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "title": { "type": "string" },
              "questionIds": { "type": "array", "items": { "type": "string" } }
            }
          }
        },
        "questions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "question": { "type": "string" },
              "options": { "type": "array", "items": { "type": "string" } },
              "correctAnswer": { "type": "number" },
              "explanation": { "type": "string" }
            }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "questions", "createdAt"]
    },
    "settings": {
      "title": "Settings",
      "description": "Global application settings.",
      "type": "object",
      "properties": {
        "visibility": {
          "type": "object",
          "properties": {
            "courses": { "type": "boolean" },
            "demo": { "type": "boolean" },
            "test": { "type": "boolean" },
            "dailyQuiz": { "type": "boolean" },
            "notes": { "type": "boolean" },
            "previousPaper": { "type": "boolean" }
          }
        }
      }
    },
    "question": {
      "title": "Question",
      "description": "A single quiz question.",
      "type": "object",
      "properties": {
        "question": { "type": "string" },
        "options": { "type": "array", "items": { "type": "string" } },
        "correctAnswer": { "type": "number" },
        "explanation": { "type": "string" },
        "category": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["question", "options", "correctAnswer", "createdAt"]
    },
    "enrollment": {
      "title": "Enrollment",
      "description": "A user enrollment in a course.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "courseId": { "type": "string" },
        "enrolledAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "courseId", "enrolledAt"]
    },
    "comment": {
      "title": "Comment",
      "description": "A comment on a test question or note.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "content": { "type": "string" },
        "targetId": { "type": "string" },
        "targetType": { "type": "string", "enum": ["question", "note"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "userName", "content", "targetId", "targetType", "createdAt"]
    }
  },
  "firestore": {
    "/inquiries/{inquiryId}": { "schema": "inquiry", "description": "User inquiries." },
    "/videos/{videoId}": { "schema": "video", "description": "YouTube videos." },
    "/courses/{courseId}": { "schema": "course", "description": "Premium courses." },
    "/notes/{noteId}": { "schema": "note", "description": "Study notes and papers." },
    "/quizzes/{quizId}": { "schema": "quiz", "description": "Interactive quizzes." },
    "/settings/visibility": { "schema": "settings", "description": "Visibility settings." },
    "/questions/{questionId}": { "schema": "question", "description": "Question bank." },
    "/enrollments/{enrollmentId}": { "schema": "enrollment", "description": "Course enrollments." },
    "/comments/{commentId}": { "schema": "comment", "description": "Comments on questions or notes." }
  }
}
